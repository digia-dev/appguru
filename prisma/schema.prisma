generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GURU
  WALI_KELAS
  KEPALA_SEKOLAH
}

enum Semester {
  GANJIL
  GENAP
}

enum AttendanceStatus {
  H
  S
  I
  A
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  passwordHash   String
  role           UserRole     @default(GURU)
  subject        String?
  phone          String?
  avatarUrl      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  teacherClasses TeacherClass[]
}

model Class {
  id        String   @id @default(cuid())
  name      String   @unique
  level     Int
  section   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  students        Student[]
  teacherClasses  TeacherClass[]
  attendance      Attendance[]
  grades          Grade[]
  learningActivities LearningActivity[]
}

model TeacherClass {
  id        String   @id @default(cuid())
  teacherId String
  classId   String
  isWaliKelas Boolean @default(false)
  createdAt DateTime @default(now())

  teacher User  @relation(fields: [teacherId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@unique([teacherId, classId])
}

model Student {
  id          String    @id @default(cuid())
  studentId   String    @unique
  name        String
  classId     String
  address     String?
  dob         DateTime?
  fatherName  String?
  fatherJob   String?
  motherName  String?
  motherJob   String?
  phone       String?
  notes       String?
  avatarUrl   String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  class      Class       @relation(fields: [classId], references: [id])
  attendance Attendance[]
  grades     Grade[]
  savings    Saving[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  label     String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  grades Grade[]
}

model Attendance {
  id             String           @id @default(cuid())
  studentId      String
  classId        String
  eventDate      DateTime
  status         AttendanceStatus
  session        Int              @default(1)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, eventDate, session])
  @@index([classId, eventDate])
  @@index([studentId])
}

model Grade {
  id              String    @id @default(cuid())
  studentId       String
  classId         String
  semester        Semester
  academicYearId  String?
  pengetahuanRata Float?
  keterampilanRata Float?
  sikapRata       Float?
  sikapJujur      String?
  sikapDisiplin   String?
  sikapTggJawab   String?
  sts             Float?
  sas             Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student     Student      @relation(fields: [studentId], references: [id])
  class       Class        @relation(fields: [classId], references: [id])
  gradeBab    GradeBab[]
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, semester])
  @@index([studentId])
  @@index([classId, semester])
}

model GradeBab {
  id              String   @id @default(cuid())
  gradeId         String
  bab             Int
  pengetahuan1    Float?
  pengetahuan2    Float?
  pengetahuan3    Float?
  pengetahuan4    Float?
  pengetahuan5    Float?
  pengetahuanRata Float?
  keterampilan1   Float?
  keterampilan2   Float?
  keterampilan3   Float?
  keterampilan4   Float?
  keterampilan5   Float?
  keterampilanRata Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  grade Grade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([gradeId, bab])
}

model LearningActivity {
  id        String   @id @default(cuid())
  classId   String
  eventDate DateTime
  startTime String
  endTime   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class Class @relation(fields: [classId], references: [id])

  @@index([classId, eventDate])
  @@index([eventDate])
}

model AcademicEvent {
  id        String   @id @default(cuid())
  title     String
  eventType String
  startDate DateTime
  endDate   DateTime?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
}

model Saving {
  id          String   @id @default(cuid())
  studentId   String
  amountIn    Float?
  amountOut   Float?
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([date])
}

model SavingWithdrawal {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model Material {
  id        String   @id @default(cuid())
  title     String
  url       String
  type      String   @default("link")
  classId   String?
  bab       Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}
